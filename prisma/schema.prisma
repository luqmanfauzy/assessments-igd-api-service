generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//
// =========================
// ENUM
// =========================
//

enum ArrivalMethod {
  WALK_IN
  STRETCHER
  WHEELCHAIR
  CARRIED
}

enum Transportation {
  AMBULANCE
  SELF
  PRIVATE
  NONE
}

enum ArrivalReason {
  SELF_ARRIVAL
  POLICE
  REFERRAL
  NONE
}

enum AirwayStatus {
  CLEAR
  PARTIAL_OBSTRUCTION
  TOTAL_OBSTRUCTION
}

enum TriageLevel {
  RED
  ORANGE
  YELLOW
  GREEN
  BLUE
  WHITE
  BLACK
}()

enum TriagePriority {
  IMMEDIATE
  EMERGENCY
  URGENT
  SEMI_URGENT
  NON_URGENT
}

enum ConsciousnessLevel {
  COMPOS_MENTIS
  APATHY
  SOMNOLENCE
  DELIRIUM
  STUPOR
  COMA
}

//
// =========================
// MASTER CASE TYPE
// =========================
//

model MasterTriageCaseType {
  id                    BigInt @id @default(autoincrement())

  code                  String @unique @db.VarChar(10)
  case_name             String @db.VarChar(100)

  description           String? @db.Text
  is_active             Boolean @default(true)

  triage_assessments    TriageAssessment[]

  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  deleted_at            DateTime?

  @@map("master_triage_case_types")
}

//
// =========================
// MASTER EXAMINATION CATEGORY
// =========================
//

model MasterTriageCategory {
  id                    BigInt @id @default(autoincrement())

  code                  String @unique @db.VarChar(20)

  category_name         String @db.VarChar(100)

  sort_order            Int?

  rules                 MasterTriageRule[]

  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  deleted_at            DateTime?

  @@map("master_triage_categories")
}

//
// =========================
// MASTER TRIAGE RULE
// =========================
//

model MasterTriageRule {
  id                    BigInt @id @default(autoincrement())

  category_id           BigInt

  category              MasterTriageCategory @relation(fields: [category_id], references: [id])

  scale                 Int

  rule_name             String @db.VarChar(150)

  description           String? @db.Text

  triage_level          TriageLevel

  priority              TriagePriority

  is_active             Boolean @default(true)

  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  deleted_at            DateTime?

  assessment_items      TriageAssessmentItem[]

  @@map("master_triage_rules")
}

//
// =========================
// TRIAGE ASSESSMENT
// =========================
//

model TriageAssessment {
  id                            BigInt @id @default(autoincrement())

  //
  // IDENTITY
  //

  visit_number                  String @db.VarChar(30)
  medical_record_number         String @db.VarChar(30)

  patient_name                  String @db.VarChar(150)

  visit_date                    DateTime

  //
  // ARRIVAL
  //

  arrival_method                ArrivalMethod

  transportation                Transportation

  arrival_reason                ArrivalReason

  notes                         String? @db.Text

  //
  // CASE TYPE
  //

  case_type_id                  BigInt?

  case_type                     MasterTriageCaseType? @relation(fields: [case_type_id], references: [id])

  //
  // COMPLAINT
  //

  chief_complaint               String @db.Text

  //
  // VITAL SIGNS
  //

  temperature                   Decimal? @db.Decimal(4,1)

  pain_scale                    Int?

  systolic_blood_pressure       Int?
  diastolic_blood_pressure      Int?

  heart_rate                    Int?

  oxygen_saturation             Decimal? @db.Decimal(5,2)

  respiratory_rate              Int?

  //
  // EXAMINATION
  //

  consciousness_level           ConsciousnessLevel?

  airway_status                 AirwayStatus?

  gcs_e                         Int?
  gcs_v                         Int?
  gcs_m                         Int?

  total_gcs                     Int?

  //
  // DOA
  //

  doa                           Boolean @default(false)

  //
  // TRIAGE RESULT
  //

  triage_level                  TriageLevel?

  triage_priority               TriagePriority?

  //
  // STAFF
  //

  assessment_time               DateTime @default(now())

  created_at                    DateTime @default(now())
  updated_at                    DateTime @updatedAt
  deleted_at                    DateTime?

  //
  // CHECKLIST DETAILS
  //

  assessment_items              TriageAssessmentItem[]

  @@index([visit_number])
  @@index([medical_record_number])
  @@index([visit_date])
  @@index([triage_level])

  @@map("triage_assessments")
}

//
// =========================
// SELECTED ASSESSMENT ITEMS
// =========================
//

model TriageAssessmentItem {
  id                            BigInt @id @default(autoincrement())

  triage_assessment_id          BigInt

  triage_assessment             TriageAssessment @relation(fields: [triage_assessment_id], references: [id])

  master_triage_rule_id         BigInt

  master_triage_rule            MasterTriageRule @relation(fields: [master_triage_rule_id], references: [id])

  notes                         String? @db.Text

  created_at                    DateTime @default(now())
  deleted_at                    DateTime?

  @@map("triage_assessment_items")
}
